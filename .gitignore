# ============================================
# LLM Wiki Obsidian Vault — .gitignore
# ============================================

# --- Obsidian 工作区（每设备不同，不追踪） ---
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace-desktop.json

# --- AI 助手会话（每次对话都变） ---
.claude/
.claudian/sessions/

# --- Learn Anything 学习数据 ---
.learn/

# --- 临时文件 / 草稿 ---
未命名*.md
手机测试*.md
测试*.md
*.tmp
*.bak

# --- 系统文件 ---
.DS_Store
Thumbs.db
desktop.ini

# --- 嵌套旧 vault（防止多设备残留） ---
GitHub/
Obsidian Vault/

# --- Node / Python 残留 ---
node_modules/
__pycache__/
