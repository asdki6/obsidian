# ============================================
# LLM Wiki Obsidian Vault — .gitignore
# ============================================

# --- 临时文件 / 草稿 ---
未命名*.md
手机测试*.md
测试*.md
*.tmp
*.bak

# --- 系统文件 ---
.DS_Store
Thumbs.db
desktop.ini

# --- 嵌套旧 vault（防止多设备残留） ---
GitHub/
Obsidian Vault/

# --- Obsidian 工作区缓存（每次打开都变，无需提交） ---
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# --- Claude 会话缓存（可选忽略，保留 schema 即可） ---
# .claudian/sessions/*.meta.json

# --- Node / Python 残留 ---
node_modules/
__pycache__/
